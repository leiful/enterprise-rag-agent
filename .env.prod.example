# Copy this file to .env.prod for production deployment.
# Keep real secrets out of Git and inject only on the server.

# Core model access
DEEPSEEK_API_KEY=replace_with_real_deepseek_api_key
# Recommended defaults tested in this repo. Change them if your provider/account uses different chat models or endpoints.
CHAT_MODEL=deepseek-v4-flash
CHAT_BASE_URL=https://api.deepseek.com
EMBEDDING_API_KEY=replace_with_real_embedding_api_key
# Recommended defaults tested in this repo. Change them if your provider/account uses different embedding or rerank models.
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4

# Production mode
APP_ENV=production

# Auth and session
APP_USERNAME=admin
APP_PASSWORD=replace_with_a_strong_production_password
SESSION_MAX_AGE_SECONDS=604800
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=lax
LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_LOCKOUT_SECONDS=300

# Database
POSTGRES_PASSWORD=replace_with_production_db_password
DATABASE_URL=postgresql://ai_agent_user:replace_with_production_db_password@postgres:5432/ai_agent
DATABASE_CONNECT_TIMEOUT_SECONDS=3

# Vector store and knowledge paths
VECTOR_STORE_BACKEND=chroma
CHROMA_COLLECTION_NAME=agent_knowledge
CHROMA_PERSIST_DIR=/app/chroma_db
DEFAULT_KNOWLEDGE_SOURCE_PATH=/app/knowledge_files

# Browser access
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.example
CORS_ALLOW_LOCALHOST_REGEX=false

# Concurrency
CHAT_MAX_CONCURRENT_REQUESTS=20
CHAT_MAX_CONCURRENT_PER_USER=1
CHAT_MAX_CONCURRENT_PER_CONVERSATION=1

# SME-oriented RAG defaults
ENABLE_QUERY_REWRITE=true
ENABLE_MULTI_QUERY=true
ENABLE_RERANK=true
RERANK_MIN_CANDIDATES=8
RECALL_K=24
DEFAULT_KNOWLEDGE_TOP_K=5
DEFAULT_KNOWLEDGE_MIN_SCORE=0.25
MULTI_QUERY_COUNT=4
HYBRID_BM25_WEIGHT=0.40
HYBRID_VECTOR_WEIGHT=0.60
ENABLE_QUERY_COVERAGE_FILTER=true
QUERY_COVERAGE_MIN=0.25
QUERY_CACHE_TTL_SECONDS=300
QUERY_CACHE_MAX_ENTRIES=128
