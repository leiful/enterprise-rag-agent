# Copy this file to .env for local development.
# Keep real secrets out of Git.

# Core model access
DEEPSEEK_API_KEY=replace_with_real_deepseek_api_key
# Recommended defaults tested in this repo. Change them if your provider/account uses different chat models or endpoints.
CHAT_MODEL=deepseek-v4-flash
CHAT_BASE_URL=https://api.deepseek.com
EMBEDDING_API_KEY=replace_with_real_embedding_api_key
# Recommended defaults tested in this repo. Change them if your provider/account uses different embedding or rerank models.
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4
# Optional: set only when rerank uses a different key or endpoint.
# RERANK_API_KEY=replace_with_real_rerank_api_key
# RERANK_API_URL=https://dashscope.aliyuncs.com/api/v1/services/rerank/text-rerank/text-rerank
RERANK_MODEL=gte-rerank-v2
RERANK_MIN_SCORE=0.20

# Application mode
APP_ENV=development

# Auth and session
APP_USERNAME=admin
APP_PASSWORD=replace_with_a_strong_local_password
SESSION_MAX_AGE_SECONDS=604800
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_LOCKOUT_SECONDS=300

# Database
# Used by compose.yml when starting local PostgreSQL.
POSTGRES_PASSWORD=replace_with_local_db_password
DATABASE_URL=postgresql://ai_agent_user:replace_with_local_db_password@localhost:5432/ai_agent
TEST_DATABASE_URL=postgresql://ai_agent_test_user:replace_with_test_db_password@localhost:5432/ai_agent_test
DATABASE_CONNECT_TIMEOUT_SECONDS=3

# Embedding dimension (depends on model, text-embedding-v4 = 1024)
EMBEDDING_DIM=1024

# Knowledge paths
# Leave unset unless you need custom locations.
# DEFAULT_KNOWLEDGE_SOURCE_PATH=/absolute/path/to/knowledge_files

# Browser access
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_LOCALHOST_REGEX=true

# Concurrency
CHAT_MAX_CONCURRENT_REQUESTS=20
CHAT_MAX_CONCURRENT_PER_USER=1
CHAT_MAX_CONCURRENT_PER_CONVERSATION=1

# SME-oriented RAG defaults: quality first, predictable cost, easy deployment.
ENABLE_QUERY_REWRITE=true
ENABLE_MULTI_QUERY=true
ENABLE_RERANK=true
RERANK_MIN_CANDIDATES=8
RECALL_K=24
DEFAULT_KNOWLEDGE_TOP_K=5
DEFAULT_KNOWLEDGE_MIN_SCORE=0.25
MULTI_QUERY_COUNT=4
HYBRID_BM25_WEIGHT=0.40
HYBRID_VECTOR_WEIGHT=0.60
ENABLE_QUERY_COVERAGE_FILTER=true
QUERY_COVERAGE_MIN=0.25
QUERY_CACHE_TTL_SECONDS=300
QUERY_CACHE_MAX_ENTRIES=128

MILVUS_URI=http://localhost:19530
MILVUS_COLLECTION=ai_agent_vectors
